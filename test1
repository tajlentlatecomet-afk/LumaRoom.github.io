<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Пе пе фатафа — основы ИИ</title>
  <style>
    :root {
      --fon: #f6f7fb;
      --beliy: #ffffff;
      --tekst: #1f2937;
      --seriy: #6b7280;
      --granica: #e5e7eb;
      --akcent: #6d5dfc;
      --akcent-svetliy: #ede9fe;
      --ten: 0 10px 30px rgba(0, 0, 0, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: var(--fon);
      color: var(--tekst);
      line-height: 1.6;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .container {
      width: min(1000px, calc(100% - 32px));
      margin: 0 auto;
    }

    .header {
      padding: 24px 0;
    }

    .shapka {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .logo {
      font-size: 24px;
      font-weight: bold;
      color: var(--akcent);
    }

    .menu {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      color: var(--seriy);
      font-size: 15px;
    }

    .hero {
      padding: 40px 0 30px;
    }

    .hero-box {
      background: var(--beliy);
      border: 1px solid var(--granica);
      border-radius: 24px;
      padding: 48px;
      box-shadow: var(--ten);
    }

    .metka {
      display: inline-block;
      background: var(--akcent-svetliy);
      color: var(--akcent);
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 14px;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0 0 16px;
      font-size: clamp(34px, 6vw, 58px);
      line-height: 1.1;
    }

    .opisanie {
      max-width: 700px;
      color: var(--seriy);
      font-size: 18px;
      margin-bottom: 26px;
    }

    .knopki {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .knopka {
      display: inline-block;
      padding: 14px 24px;
      border-radius: 14px;
      font-weight: bold;
      transition: 0.2s;
    }

    .knopka-glavnaya {
      background: var(--akcent);
      color: white;
    }

    .knopka-glavnaya:hover {
      opacity: 0.9;
    }

    .knopka-prostaya {
      background: white;
      border: 1px solid var(--granica);
      color: var(--tekst);
    }

    .sekciya {
      padding: 26px 0;
    }

    .zagolovok {
      margin: 0 0 10px;
      font-size: 32px;
    }

    .podzagolovok {
      margin: 0 0 24px;
      color: var(--seriy);
    }

    .kartochki {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 1fr;
      gap: 18px;
    }

    /* 1 длинный слева */
    .kartochki .kartochka:nth-child(1) {
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    /* 2 сверху справа */
    .kartochki .kartochka:nth-child(2) {
      grid-column: 2;
      grid-row: 1;
    }

    /* 3 снизу справа */
    .kartochki .kartochka:nth-child(3) {
      grid-column: 2;
      grid-row: 2;
    }

    .kartochka {
      background: var(--beliy);
      border: 1px solid var(--granica);
      border-radius: 20px;
      padding: 24px;
      box-shadow: var(--ten);
    }

    .nomer {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: var(--akcent-svetliy);
      color: var(--akcent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      margin-bottom: 14px;
    }

    .kartochka h3 {
      margin: 0 0 10px;
      font-size: 20px;
    }

    .kartochka p {
      margin: 0;
      color: var(--seriy);
    }

    .blok-niz {
      margin-top: 20px;
      background: var(--beliy);
      border: 1px solid var(--granica);
      border-radius: 24px;
      padding: 32px;
      box-shadow: var(--ten);
    }

    .ssylki {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .soc {
      display: inline-block;
      padding: 12px 18px;
      background: white;
      border: 1px solid var(--granica);
      border-radius: 12px;
      color: var(--tekst);
    }

    .footer {
      padding: 30px 0 40px;
      color: var(--seriy);
      font-size: 14px;
    }

    @media (max-width: 850px) {
      .kartochki {
        grid-template-columns: 1fr;
      }

      .kartochka,
      .kartochki .kartochka:nth-child(1),
      .kartochki .kartochka:nth-child(2),
      .kartochki .kartochka:nth-child(3) {
        grid-column: auto;
      }

      .hero-box,
      .blok-niz {
        padding: 28px;
      }
    }

      .hero-box,
      .blok-niz {
        padding: 28px;
      }
    }
  </style>
</head>
<body>
  <header class="header">
